        n.t=/(\\\<)|<(st|[cworis]) *([^>]+)?>/g;
    }
    if(l=="")return[""];

    const r=[],e=new Map;
    let t="",c=0;

    for(let{index:f,0:u,1:a,2:o,3:i}of[...l.matchAll(n.t),{index:l.length}]){
        t+=l.slice(c,f);
